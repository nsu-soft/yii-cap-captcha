{
    "type": "object",
    "properties": {
        "key": {
            "type": "object",
            "properties": {
                "siteKey": {
                    "type": "string",
                    "minLength": 10,
                    "maxLength": 10
                },
                "name": {
                    "type": "string"
                },
                "created": {
                    "type": "number"
                },
                "config": {
                    "type": "object",
                    "properties": {
                        "difficulty": {
                            "type": "number"
                        },
                        "challengeCount": {
                            "type": "number"
                        },
                        "saltSize": {
                            "type": "number"
                        }
                    },
                    "required": ["difficulty", "challengeCount", "saltSize"]
                }
            },
            "required": ["siteKey", "name", "created", "config"]
        },
        "stats": {
            "type": "object",
            "properties": {
                "solvesLast24h": {
                    "type": "number"
                }
            },
            "required": ["solvesLast24h"]
        },
        "chartData": {
            "type": "object",
            "properties": {
                "duration": {
                    "type": "string"
                },
                "bucketSize": {
                    "type": "number"
                },
                "data": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "bucket": {
                                "type": "number"
                            },
                            "count": {
                                "type": "number"
                            }
                        },
                        "required": ["bucket", "count"]
                    }
                }
            },
            "required": ["duration", "bucketSize", "data"]
        }
    },
    "required": ["key", "stats", "chartData"]
}